REKA_API_KEY=

# ── AI Gateways / Aggregators ───────────────────────────────

OPENROUTER_API_KEY=                # multi-model gateway
TOGETHER_API_KEY=                  # hosted open-source
OLLAMA_BASE_URL=                   # local models

# ── Memory (Mem0) ──────────────────────────────────────────
# Mem0 provides semantic, LLM-powered memory for agents.
# Requires: Supabase (vector store), OpenAI (embeddings), Anthropic (fact extraction).
# All three must be configured for mem0 to activate; otherwise falls back to in-memory.
# Note: OPENAI_API_KEY is used for text-embedding-3-small embeddings.
# Note: ANTHROPIC_API_KEY is used for LLM-powered fact extraction (claude-haiku).

# ── Embeddings & Search ─────────────────────────────────────

VOYAGE_API_KEY=                    # Voyage AI embeddings
JINA_API_KEY=                      # Jina embeddings & reranking

# ── Image Generation ────────────────────────────────────────

STABILITY_API_KEY=                 # Stability AI (Stable Diffusion)
FAL_KEY=                           # fal.ai (FLUX, fast inference)
MIDJOURNEY_API_KEY=                # Midjourney
LEONARDO_API_KEY=                  # Leonardo AI
IDEOGRAM_API_KEY=                  # Ideogram
CLIPDROP_API_KEY=                  # ClipDrop (Stability)
GETIMG_API_KEY=                    # getimg.ai
NOVITA_API_KEY=                    # Novita AI

# ── Video Generation ───────────────────────────────────────

RUNWAY_API_KEY=                    # Runway Gen-3/4
LUMA_API_KEY=                      # Luma Dream Machine
KLING_API_KEY=                     # Kling AI
SEEDANCE_API_KEY=                  # Seedance (ByteDance)
PIKA_API_KEY=                      # Pika Labs
HAIPER_API_KEY=                    # Haiper AI
VIDU_API_KEY=                      # Vidu AI
MINIMAX_VIDEO_API_KEY=             # MiniMax Video (Hailuo)
GENMO_API_KEY=                     # Genmo (Mochi)
PIXVERSE_API_KEY=                  # PixVerse

# ── Music & Audio Generation ──────────────────────────────

SUNO_API_KEY=                      # Suno (music gen)
UDIO_API_KEY=                      # Udio (music gen)

# ── Voice & TTS / STT ─────────────────────────────────────

ELEVENLABS_API_KEY=                # ElevenLabs (voice cloning, TTS)
FISH_AUDIO_API_KEY=                # Fish Audio (multilingual TTS)
CARTESIA_API_KEY=                  # Cartesia (ultra-low latency TTS)
RESEMBLE_API_KEY=                  # Resemble AI (voice cloning)
PLAY_HT_API_KEY=                   # Play.ht (TTS)
PLAY_HT_USER_ID=
MURF_API_KEY=                      # Murf AI (TTS)
NEETS_API_KEY=                     # Neets.ai (TTS)
DEEPGRAM_API_KEY=                  # Deepgram (STT + TTS)
ASSEMBLY_AI_API_KEY=               # AssemblyAI (STT + audio intelligence)
SPEECHIFY_API_KEY=                 # Speechify (TTS)
WHISPER_API_KEY=                   # OpenAI Whisper (STT) — uses OPENAI_API_KEY

# ── 3D & Avatar ───────────────────────────────────────────

MESHY_API_KEY=                     # Meshy (3D model gen)
TRIPO_API_KEY=                     # Tripo AI (3D gen)
HEYGEN_API_KEY=                    # HeyGen (avatar video)
SYNTHESIA_API_KEY=                 # Synthesia (avatar video)
DID_API_KEY=                       # D-ID (talking avatar)

# ── Code & Dev Tools ──────────────────────────────────────

CODEIUM_API_KEY=                   # Codeium / Windsurf
SOURCEGRAPH_API_KEY=               # Sourcegraph / Cody
TABNINE_API_KEY=                   # Tabnine
CODESTRAL_API_KEY=                 # Codestral (Mistral code)
CURSOR_API_KEY=                    # Cursor

# ── Search & Data ─────────────────────────────────────────

SERPER_API_KEY=                    # Serper (Google search API)
SERPAPI_API_KEY=                   # SerpAPI
TAVILY_API_KEY=                    # Tavily (AI search)
EXA_API_KEY=                       # Exa (neural search)
BRAVE_SEARCH_API_KEY=              # Brave Search
BING_SEARCH_API_KEY=               # Bing Search
FIRECRAWL_API_KEY=                 # Firecrawl (web scraping)
BROWSERLESS_API_KEY=               # Browserless (headless browser)
APIFY_API_TOKEN=                   # Apify (web scraping)
DIFFBOT_API_KEY=                   # Diffbot (structured data)

# ── Translation & NLP ─────────────────────────────────────

DEEPL_API_KEY=                     # DeepL (translation)
NLPCLOUD_API_KEY=                  # NLP Cloud

# ── Composio (500+ app integrations for agents) ─────────
# Composio gives agents access to GitHub, Slack, Notion, Jira,
# Salesforce, HubSpot, and 500+ more apps via a unified SDK.
# Sign up at https://composio.dev to get your API key.
COMPOSIO_API_KEY=

# ── Automation & Agents ───────────────────────────────────

LANGCHAIN_API_KEY=                 # LangSmith (tracing)
LANGFUSE_PUBLIC_KEY=               # Langfuse (observability)
LANGFUSE_SECRET_KEY=
HELICONE_API_KEY=                  # Helicone (observability)

# ── Communication ─────────────────────────────────────────

SENDGRID_API_KEY=                  # SendGrid (email)
RESEND_API_KEY=                    # Resend (email)
TWILIO_ACCOUNT_SID=                # Twilio (SMS/voice)
TWILIO_AUTH_TOKEN=
SLACK_BOT_TOKEN=                   # Slack integration
DISCORD_BOT_TOKEN=                 # Discord integration
TELEGRAM_BOT_TOKEN=                # Telegram integration

# ── 1P OS Smart Router ───────────────────────────────────
# Skip all the keys above — let 1P OS route to the best
# model/provider automatically. One key to rule them all.
ONEPOS_ROUTER_ENABLED=false        # set true to use smart router
ONEPOS_ROUTER_API_KEY=             # your 1P OS platform key

# ── Payments ──────────────────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
LEMONSQUEEZY_API_KEY=              # Lemon Squeezy (alt payments)

# ── Cache ─────────────────────────────────────────────────

REDIS_URL=
UPSTASH_REDIS_URL=                 # Upstash (serverless Redis)
UPSTASH_REDIS_TOKEN=

# ── Storage ───────────────────────────────────────────────

AWS_ACCESS_KEY_ID=                 # S3
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY=          # Cloudflare R2
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=
UPLOADTHING_SECRET=                # UploadThing

# ── OAuth (for integrations / connected accounts) ────────

GOOGLE_CLIENT_ID=                  # Gmail, Calendar, Drive
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=               # Outlook / Microsoft 365
MICROSOFT_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ── Security ─────────────────────────────────────────────

ENCRYPTION_KEY=                    # openssl rand -hex 32

# ── LLMRouter (intelligent model routing) ────────────────
# See: https://github.com/ulab-uiuc/LLMRouter
# Enable to use ML-based routing via the LLMRouter sidecar
LLM_ROUTER_ENABLED=false
LLM_ROUTER_URL=http://localhost:8000   # LLMRouter serve endpoint
LLM_ROUTER_TIMEOUT_MS=3000             # Max wait for sidecar response

# ── Self-hosted model (optional) ─────────────────────────

SELF_HOSTED_MODEL_ID=
SELF_HOSTED_MODEL_NAME=
SELF_HOSTED_COST_PER_INPUT_TOKEN=0.0
SELF_HOSTED_COST_PER_OUTPUT_TOKEN=0.0
SELF_HOSTED_LATENCY_MS=100
SELF_HOSTED_MAX_CONTEXT=8192
SELF_HOSTED_QUALITY_TIER=medium

# ── App ───────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000
