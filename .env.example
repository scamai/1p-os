# Deployment mode
DEPLOYMENT_MODE=cloud              # "cloud" or "self-hosted"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI — primary
ANTHROPIC_API_KEY=

# AI — fallback (configure based on preference)
OLLAMA_BASE_URL=                   # local models
TOGETHER_API_KEY=                  # hosted open-source
OPENROUTER_API_KEY=                # multi-model gateway

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cache
REDIS_URL=

# Security
ENCRYPTION_KEY=                    # openssl rand -hex 32

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
