# Deployment mode
DEPLOYMENT_MODE=cloud              # "cloud" or "self-hosted"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI Providers ─────────────────────────────────────────────

# Primary
ANTHROPIC_API_KEY=

# OpenAI / GPT
OPENAI_API_KEY=

# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Cohere
COHERE_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# MiniMax
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Moonshot / Kimi
MOONSHOT_API_KEY=

# Zhipu AI (GLM)
ZHIPUAI_API_KEY=

# Baichuan
BAICHUAN_API_KEY=

# Yi (01.AI)
YI_API_KEY=

# Qwen (Alibaba / DashScope)
DASHSCOPE_API_KEY=

# Perplexity
PERPLEXITY_API_KEY=

# Groq
